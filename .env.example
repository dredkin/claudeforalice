# ── Dashboard ────────────────────────────────────────────────────────────
# Password for the web dashboard at /dashboard
DASHBOARD_PASSWORD=change_me_please

# Flask session secret key (set a long random string for production)
# Generate one: python3 -c "import secrets; print(secrets.token_hex(32))"
SECRET_KEY=

# SQLite database file path for persistent dialog history.
# Default: dialogs.db in the same directory as the app scripts.
# Override only if you want to store the DB elsewhere.
# DB_PATH=/custom/path/to/dialogs.db

# ── Web search (Anthropic built-in tool) ─────────────────────────────────
# WARNING: additional cost ~$10 per 1000 searches ON TOP of normal token cost.
# Enable only if you need real-time information (news, prices, weather, etc.)
ENABLE_WEB_SEARCH=false
# Max web search calls per user request (1-5)
WEB_SEARCH_MAX_RESULTS=3

# ── User context (injected into Claude's system prompt) ──────────────────
# City, region or any description of the user's location.
# If left blank, the server's public IP is used to auto-detect location
# via https://ipapi.co (free, no key required, cached for the process lifetime).
# USER_LOCATION=Москва, Россия

# Timezone for current date/time displayed to Claude (IANA tz name).
# If left blank or set to default, auto-detected from server IP.
# USER_TIMEZONE=Europe/Moscow

# ── Anthropic / Claude ────────────────────────────────────────────────────
# Get your key at https://console.anthropic.com/
ANTHROPIC_API_KEY=sk-ant-...

# Claude model to use (default: claude-opus-4-5)
CLAUDE_MODEL=claude-opus-4-6

# Maximum tokens in Claude's reply
CLAUDE_MAX_TOKENS=1024

# System prompt (override if needed)
# CLAUDE_SYSTEM_PROMPT=Ты голосовой ИИ-ассистент внутри навыка Яндекс Алисы...

# How many user↔assistant turns to keep in memory per user (default: 20)
MAX_HISTORY_TURNS=20

# Session inactivity timeout in minutes. After this period of silence the
# conversation history is cleared and a new DB session begins (default: 5).
SESSION_TIMEOUT_MINUTES=5

# Seconds to wait for Claude before returning "Клод думает…" to Alice.
# Alice webhook timeout is ~5 s; keep this value lower (default: 3.0).
# If Claude replies in time — answer is spoken immediately.
# If not — user asks "что ответил?" to get the deferred answer.
ALICE_REPLY_TIMEOUT=3.0

# ── Flask ─────────────────────────────────────────────────────────────────
FLASK_HOST=127.0.0.1
FLASK_PORT=37842
FLASK_DEBUG=false

# ── Alice skill verification (optional) ──────────────────────────────────
# Set to the OAuth token from your Alice skill settings to verify requests.
# Leave blank to disable verification.
ALICE_SKILL_TOKEN=
