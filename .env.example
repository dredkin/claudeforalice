# ── Anthropic / Claude ────────────────────────────────────────────────────
# Get your key at https://console.anthropic.com/
ANTHROPIC_API_KEY=sk-ant-...

# Claude model to use (default: claude-opus-4-5)
CLAUDE_MODEL=claude-opus-4-6

# Maximum tokens in Claude's reply
CLAUDE_MAX_TOKENS=1024

# System prompt (override if needed)
# CLAUDE_SYSTEM_PROMPT=Ты голосовой ИИ-ассистент внутри навыка Яндекс Алисы...

# How many user↔assistant turns to keep in memory per user (default: 20)
MAX_HISTORY_TURNS=20

# Seconds to wait for Claude before returning "Клод думает…" to Alice.
# Alice webhook timeout is ~5 s; keep this value lower (default: 3.0).
# If Claude replies in time — answer is spoken immediately.
# If not — user asks "что ответил?" to get the deferred answer.
ALICE_REPLY_TIMEOUT=3.0

# ── Flask ─────────────────────────────────────────────────────────────────
FLASK_HOST=127.0.0.1
FLASK_PORT=37842
FLASK_DEBUG=false

# ── Alice skill verification (optional) ──────────────────────────────────
# Set to the OAuth token from your Alice skill settings to verify requests.
# Leave blank to disable verification.
ALICE_SKILL_TOKEN=
